{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(rm)",
      "Bash(rm:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D)",
      "Bash(git branch -D:*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git commit --no-verify)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n)",
      "Bash(git commit -n:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stop.sh"
          }
        ]
      }
    ]
  }
}
