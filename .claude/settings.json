{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Edit(.claude/.workflow-state)",
      "Write(.claude/.workflow-state)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm uninstall:*)",
      "Bash(npx expo install:*)",
      "Bash(npx expo-doctor:*)",
      "Bash(dotnet add:*)",
      "Bash(dotnet restore)",
      "Bash(dotnet restore:*)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ../*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D)",
      "Bash(git branch -D:*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git commit --no-verify)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n)",
      "Bash(git commit -n:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stop.sh"
          }
        ]
      }
    ]
  }
}
