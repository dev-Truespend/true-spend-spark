    "RewardsCcCatalogReconcile":{ "Enabled": false, "Cron": "0 4 * * 0",   "MaxRetries": 3, "BatchSize": 200, "DryRun": true },
    "AdminNotificationDispatch":{ "Enabled": false, "Cron": "0 9 * * *",   "MaxRetries": 3, "BatchSize": 5000 },
