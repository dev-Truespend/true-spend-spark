# TrueSpend backend — production env template for docker-compose.prod.yml.
# Copy to docker/.env.prod and fill values, OR (preferred in Azure) inject these as
# Container App secrets sourced from Key Vault — see _docs/Deployment/deployment-guide.md.
# docker/.env.prod is gitignored (root .gitignore: .env.*). NEVER commit real secrets.
#
# .NET binds nested config with the double-underscore convention: Section__Key.
# Both the API and worker containers read ConnectionStrings__TrueSpendDb; the worker
# additionally needs AzureOpenAI__*, RewardsCc__*, and Plaid__* (nightly sync).

# ── Database (Supabase Postgres) — SECRET — api + worker ──────────────────────
# Use the Supabase connection-pooler string (port 6543) for app containers.
ConnectionStrings__TrueSpendDb=Host=aws-0-REGION.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# ── Supabase JWT validation — api ────────────────────────────────────────────
Supabase__JwtIssuer=https://YOUR_PROJECT_REF.supabase.co/auth/v1
Supabase__JwtAudience=authenticated
Supabase__JwtSecret=YOUR_SUPABASE_JWT_SECRET                # SECRET

# ── Supabase Storage + Admin (account deletion purge) — SECRET — api ─────────
SupabaseStorage__Url=https://YOUR_PROJECT_REF.supabase.co
SupabaseStorage__ServiceRoleKey=YOUR_SUPABASE_SERVICE_ROLE_KEY   # SECRET (full DB bypass)
SupabaseStorage__PublicBaseUrl=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public

# ── Stripe (billing) — api ───────────────────────────────────────────────────
Stripe__SecretKey=sk_live_or_test_xxx                       # SECRET
Stripe__PublishableKey=pk_live_or_test_xxx                  # publishable (not secret)
Stripe__WebhookSecret=whsec_xxx                             # SECRET (signing secret)

# ── Plaid (bank linking + transactions) — api + worker ───────────────────────
Plaid__ClientId=YOUR_PLAID_CLIENT_ID                        # SECRET
Plaid__Secret=YOUR_PLAID_SECRET                             # SECRET (per-environment)
Plaid__Environment=sandbox                                  # sandbox | production

# ── Resend (transactional email) — api ───────────────────────────────────────
Resend__ApiKey=re_xxx                                       # SECRET
Resend__FromAddress=TrueSpend <no-reply@truespend.app>

# ── Azure OpenAI (AI insights, worker job) — worker ──────────────────────────
AzureOpenAI__Endpoint=https://YOUR-AOAI.openai.azure.com/
AzureOpenAI__ApiKey=YOUR_AZURE_OPENAI_KEY                   # SECRET
AzureOpenAI__DeploymentName=gpt-4o-mini

# ── RewardsCC catalog provider (worker job) — worker ─────────────────────────
RewardsCc__BaseUrl=https://rewards-credit-card-api.p.rapidapi.com
RewardsCc__ApiKey=YOUR_RAPIDAPI_KEY                         # SECRET
RewardsCc__Host=rewards-credit-card-api.p.rapidapi.com

# ── Foursquare webhook (geo) — DEFERRED — api ────────────────────────────────
Foursquare__WebhookSecret=                                  # SECRET (set when geo is enabled)

# ── ServiceBus — DORMANT in MVP (async converted to inline post-commit) ──────
# Only needed if the eventconsumer container is re-enabled. Leave blank for MVP.
# ServiceBus__ConnectionString=
