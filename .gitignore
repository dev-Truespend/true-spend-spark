.DS_Store
node_modules/
dist/
build/
coverage/
TestResults/

# .NET build outputs
bin/
obj/

# .NET local dev secrets — tracked appsettings.*.json must hold NO real secrets.
# Put local keys in user-secrets (`dotnet user-secrets`) or a gitignored local override.
appsettings.*.local.json
appsettings.Local.json
appsettings.local.json

# Expo / React Native local state
.expo/
.expo-shared/

# Native projects are CNG build output — regenerated by `expo prebuild` (run by EAS
# on every build) from app.config.ts + config plugins. Keeping them out of git is what
# guarantees config-plugin changes (URL schemes, entitlements, pods) actually land in
# the binary. Do not commit these; edit app.config.ts / add a config plugin instead.
ui-mobile/ios/
ui-mobile/android/

# Supabase local state
supabase/.temp/

# Local environment files — every real .env (any dir, any suffix) is ignored;
# only *.example templates stay tracked.
.env
.env.*
*.env.local
!.env.example
!.env.*.example

# Terraform — state, plans, vars, provider cache (state holds secrets in plaintext)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log
*.tfvars
!*.tfvars.example

# Expo / EAS credentials and Apple/Android signing material (certs & keys)
ui-mobile/credentials.json
*.p8
*.p12
*.mobileprovision
*.keystore
AuthKey_*.p8

# Codex workflow session state
.codex/.workflow-state

# Claude Code — personal overrides (team-shared settings.json is committed)
.claude/settings.local.json
# Claude Code — session state (workflow gate for Stop hook)
.claude/.workflow-state

# Vercel local project metadata
.vercel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
