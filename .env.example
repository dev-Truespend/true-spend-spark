# ─── Supabase ────────────────────────────────────────────────────────────────
# Project reference ID (found in Supabase dashboard → Settings → General)
VITE_SUPABASE_PROJECT_ID=your_project_id

# Public anon key (safe to expose in browser bundles)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Project URL  e.g. https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# ─── App ─────────────────────────────────────────────────────────────────────
# Canonical origin used in OAuth redirects and email links.
# In development this is usually http://localhost:8080
# In production set to your real domain e.g. https://app.truespend.com
VITE_APP_URL=http://localhost:8080

# Server-side canonical origin for Supabase Edge Functions.
# Keep this equal to VITE_APP_URL in production.
APP_URL=http://localhost:8080

# Backward-compatible aliases used by older Edge Functions.
SITE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Publishable key — safe to expose in browser bundles (pk_live_... or pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Price IDs for each billing tier (from Stripe Dashboard → Products)
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_your_pro_annual

# Server-side Stripe secrets for Supabase Edge Functions. Do not expose these
# in browser builds; configure them with `supabase secrets set`.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_pro_annual
STRIPE_PRO_PRICE_IDS=price_your_pro_monthly,price_your_pro_annual
STRIPE_ENTERPRISE_PRICE_IDS=

# ─── Email / notifications ─────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=TrueSpend <noreply@your-domain.com>

# ─── Plaid ──────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENVIRONMENT=sandbox

# ─── Maps / places ──────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_browser_restricted_google_maps_key
GOOGLE_MAPS_BACKEND_KEY=your_server_restricted_google_maps_key

# ─── Cache / rate limiting ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── AI providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
GEMINI_API_KEY=your_gemini_key
HUGGING_FACE_ACCESS_TOKEN=hf_your_token

# ─── Location and mobile notifications ──────────────────────────────────────
LOCATION_SIGNING_SECRET=replace_with_32_plus_random_bytes
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
IOS_APNS_KEY=-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----
IOS_APNS_KEY_ID=your_apns_key_id
IOS_APNS_TEAM_ID=your_apple_team_id

# ─── Internal ML training / webhooks ────────────────────────────────────────
MODAL_API_TOKEN=your_modal_token
MODAL_WEBHOOK_SECRET=your_modal_webhook_secret

# ─── Supabase server-side aliases for local Edge Function development ───────
# Supabase hosted functions provide modern SUPABASE_PUBLISHABLE_KEYS /
# SUPABASE_SECRET_KEYS automatically, but many existing functions still read
# these legacy names locally.
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_never_expose_in_browser

# ─── Optional / infrastructure ───────────────────────────────────────────────
# REST base used by server-side code (Edge Functions) — not exposed to browser
VITE_API_ORIGIN=http://localhost:8080

# URI where the browser POSTs CSP violation reports (leave blank to disable)
VITE_CSP_REPORT_URI=

# Set to "true" to show a maintenance banner and block all routes
VITE_MAINTENANCE_MODE=false

# Set to "true" to enable PWA service worker (off by default in dev)
VITE_PWA_ENABLED=false
