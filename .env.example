# ─── Supabase ────────────────────────────────────────────────────────────────
# Project reference ID (found in Supabase dashboard → Settings → General)
VITE_SUPABASE_PROJECT_ID=your_project_id

# Public anon key (safe to expose in browser bundles)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Project URL  e.g. https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# ─── App ─────────────────────────────────────────────────────────────────────
# Canonical origin used in OAuth redirects and email links.
# In development this is usually http://localhost:8080
# In production set to your real domain e.g. https://app.truespend.com
VITE_APP_URL=http://localhost:8080

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Publishable key — safe to expose in browser bundles (pk_live_... or pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Price IDs for each billing tier (from Stripe Dashboard → Products)
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_your_pro_annual

# ─── Optional / infrastructure ───────────────────────────────────────────────
# REST base used by server-side code (Edge Functions) — not exposed to browser
VITE_API_ORIGIN=http://localhost:8080

# URI where the browser POSTs CSP violation reports (leave blank to disable)
VITE_CSP_REPORT_URI=

# Set to "true" to show a maintenance banner and block all routes
VITE_MAINTENANCE_MODE=false

# Set to "true" to enable PWA service worker (off by default in dev)
VITE_PWA_ENABLED=false
