# TrueSpend mobile — environment template.
# Copy to .env.local (dev), .env.staging, .env.production. Real files are gitignored
# (root .gitignore: .env.* with a !.env.example exception). NEVER commit real values.
#
# Everything prefixed EXPO_PUBLIC_ is bundled into the client binary and is therefore
# NOT secret — it ships to every device. Keep true secrets out of the app entirely;
# they live in the backend / Key Vault. The Supabase ANON key is publishable by design
# (RLS enforces access), so it is safe here.

# Which env profile this file represents: development | staging | production
APP_ENV=development

# Base URL of the TrueSpend .NET API (Azure Container App ingress FQDN in cloud envs).
# Dev example over LAN: http://192.168.1.50:5000
EXPO_PUBLIC_API_BASE_URL=https://api-truespend-dev.azurecontainerapps.io

# Supabase project — used for auth (Apple/Google/email OTP) and JWT issuance.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Plaid OAuth redirect URI (must match the Plaid dashboard allowed redirect URIs).
# Universal/App Link, e.g. https://truespend.app/plaid-oauth
EXPO_PUBLIC_PLAID_REDIRECT_URI=

# Foursquare Movement SDK key — DEFERRED (geo not enabled yet). Leave blank for now.
EXPO_PUBLIC_FOURSQUARE_API_KEY=

# EAS project id (from `eas init`; visible in app.config.ts extra.eas.projectId).
EXPO_PUBLIC_EAS_PROJECT_ID=
